#!/usr/bin/env bash

# This tool is used to create universal binaries of Homebrew-installed shared
# libraries. This is needed to build universal (x86_64 and arm64) binaries on
# macOS.

set -e

for COMMAND_DEPENDENCY in "jq" "wget"; do
  if ! command -v $COMMAND_DEPENDENCY &> /dev/null; then
      printf "'$COMMAND_DEPENDENCY' could not be found. Install via: brew install $COMMAND_DEPENDENCY\n" >&2
      exit 1
  fi
done

MACOS_VERSION=$(/usr/bin/sw_vers -productVersion)

case $MACOS_VERSION in
15.*) MACOS_RELEASE="sequoia" ;;
14.*) MACOS_RELEASE="sonoma" ;;
13.*) MACOS_RELEASE="ventura" ;;
12.*) MACOS_RELEASE="monterey" ;;
11.*) MACOS_RELEASE="big_sur" ;;
10.15.*) MACOS_RELEASE="catalina" ;;
10.14.*) MACOS_RELEASE="mojave" ;;
10.13.*) MACOS_RELEASE="high_sierra" ;;
10.12.*) MACOS_RELEASE="sierra" ;;
10.11.*) MACOS_RELEASE="el_capitan" ;;
esac

if [ -z "$MACOS_RELEASE" ]; then
  printf "Cannot get macOS release from version: $MACOS_VERSION\n" >&2
  exit 1
fi

HOMEBREW_PREFIX=$(brew --prefix)
ARCH_THIS=$(uname -m)

if [ "$ARCH_THIS" == "arm64" ]; then
  ARCH_OTHER=x86_64
  HOMEBREW_PREFIX_OTHER=/usr/local
  DOWNLOAD_PROPERTY=$MACOS_RELEASE
  FALLBACK_PROPERTY="sonoma"
else
  ARCH_OTHER=arm64
  HOMEBREW_PREFIX_OTHER=/opt/homebrew
  DOWNLOAD_PROPERTY="arm64_$MACOS_RELEASE"
  FALLBACK_PROPERTY="arm64_sonoma"
fi

HOMEBREW_CELLAR_OTHER=$HOMEBREW_PREFIX_OTHER/Cellar

WORK_DIR=$(mktemp -d)

brew update

# brew bundle (an earlier step) installs this-arch formulae against
# whatever the tap knew at that time. The `brew update` above can move the
# tap's notion of "current" forward without touching what's actually
# installed -- `update` and `upgrade` are different things in Homebrew.
# Everything below resolves versions against the post-update tap, so if we
# don't also bring the already-installed side up to match, the merge loop
# ends up looking for a version that was never actually installed here,
# quietly skips the merge, and leaves the original single-arch library
# untouched (surfacing later as a linker "wrong architecture" error rather
# than failing here where it'd be obvious).
brew upgrade "$@"

echo "Homebrew prefix: $HOMEBREW_PREFIX"
echo "macOS release: $MACOS_RELEASE [$ARCH_THIS]"
echo "brew info download property: $DOWNLOAD_PROPERTY"
echo "Work directory: $WORK_DIR"

BREW_INFO_JSON=$(brew info --json "$@")

info=$(echo "$BREW_INFO_JSON" | jq -r '.[] | "\(.name): \(.bottle.stable.files | keys | join(", "))"')
echo "info: $info"

# Homebrew has been dropping Intel bottles for actively-updated formulae
# ahead of its documented September 2026 Intel deprecation. That means
# files[$prop] -- and even the documented "fall back to the previous OS's
# Intel bottle" behavior -- can legitimately be absent. Split dependencies
# into those with a usable bottle and those we'll build from source instead.
BOTTLED_FORMULAE=()
while IFS= read -r NAME; do
  [ -n "$NAME" ] && BOTTLED_FORMULAE+=("$NAME")
done < <(echo "$BREW_INFO_JSON" | jq -r --arg prop "$DOWNLOAD_PROPERTY" --arg fallback "$FALLBACK_PROPERTY" \
  '.[] | select((.bottle.stable.files[$prop] // .bottle.stable.files[$fallback])) | .name')

SOURCE_FORMULAE=()
while IFS= read -r NAME; do
  [ -n "$NAME" ] && SOURCE_FORMULAE+=("$NAME")
done < <(echo "$BREW_INFO_JSON" | jq -r --arg prop "$DOWNLOAD_PROPERTY" --arg fallback "$FALLBACK_PROPERTY" \
  '.[] | select((.bottle.stable.files[$prop] // .bottle.stable.files[$fallback]) | not) | .name')

DOWNLOAD_URLS=$(echo "$BREW_INFO_JSON" | jq -r --arg prop "$DOWNLOAD_PROPERTY" --arg fallback "$FALLBACK_PROPERTY" \
  '.[] | (.bottle.stable.files[$prop] // .bottle.stable.files[$fallback]).url // empty')

echo "Bottled (${#BOTTLED_FORMULAE[@]}): ${BOTTLED_FORMULAE[*]:-none}"
echo "From source (${#SOURCE_FORMULAE[@]}): ${SOURCE_FORMULAE[*]:-none}"
echo "urls: $DOWNLOAD_URLS"

if [ -n "$DOWNLOAD_URLS" ]; then
  echo "$DOWNLOAD_URLS" | wget --no-verbose -P "$WORK_DIR" --header "Authorization: Bearer QQ==" -i -

  for DOWNLOAD_URL in $DOWNLOAD_URLS; do
    tar xfz "$WORK_DIR/$(basename "$DOWNLOAD_URL")" -C "$WORK_DIR"
  done
fi

if [ ${#SOURCE_FORMULAE[@]} -gt 0 ]; then
  BREW_OTHER="$HOMEBREW_PREFIX_OTHER/bin/brew"

  if [ ! -x "$BREW_OTHER" ]; then
    # Rosetta 2 only translates x86_64 -> arm64, never the reverse, so an
    # Intel machine cannot run arm64 code at all -- bootstrapping is
    # impossible here, not just missing.
    if [ "$ARCH_OTHER" = "arm64" ]; then
      echo "No arm64 Homebrew at $HOMEBREW_PREFIX_OTHER, and none can be bootstrapped here:" >&2
      echo "Rosetta 2 translates x86_64 -> arm64, not the reverse, so arm64 code can't" >&2
      echo "run on this Intel machine at all. Build $ARCH_OTHER natively on Apple Silicon." >&2
      exit 1
    fi

    echo "No $ARCH_OTHER Homebrew at $HOMEBREW_PREFIX_OTHER for: ${SOURCE_FORMULAE[*]}"
    echo "Bootstrapping one now (one-time setup; later runs on this machine will skip this)."

    NONINTERACTIVE=1 arch "-$ARCH_OTHER" /bin/bash -c \
      "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [ ! -x "$BREW_OTHER" ]; then
      echo "Bootstrapped $ARCH_OTHER Homebrew, but $BREW_OTHER still doesn't exist" >&2
      echo "(installer may have failed, or installed to a different prefix)." >&2
      exit 1
    fi

    echo "$ARCH_OTHER Homebrew ready at $HOMEBREW_PREFIX_OTHER"
  fi

  # Skip anything a restored cache already provided (see the workflow's
  # actions/cache step, keyed on resolved formula versions) -- checked
  # against the *exact* versions.stable directory, not just "something is
  # there", so a stale/wrong-version cache entry safely falls through to a
  # rebuild instead of being mistaken for a hit.
  TO_BUILD=()
  for SOURCE_FORMULA in "${SOURCE_FORMULAE[@]}"; do
    SOURCE_VERSION=$(echo "$BREW_INFO_JSON" | jq -r --arg name "$SOURCE_FORMULA" '.[] | select(.name == $name) | .versions.stable')
    if [ -d "$HOMEBREW_CELLAR_OTHER/$SOURCE_FORMULA/$SOURCE_VERSION" ]; then
      echo "$SOURCE_FORMULA $SOURCE_VERSION already present under $HOMEBREW_CELLAR_OTHER (cache hit) -- skipping build"
    else
      TO_BUILD+=("$SOURCE_FORMULA")
    fi
  done

  if [ ${#TO_BUILD[@]} -gt 0 ]; then
    echo "Building from source for $ARCH_OTHER: ${TO_BUILD[*]}"

    arch "-$ARCH_OTHER" "$BREW_OTHER" update

    # Some formulae (e.g. openssl@3) hardcode their own internal test suite
    # inside `install` itself, with no install-time flag to disable it --
    # unlike `brew test`, which never runs automatically, this always runs
    # on a from-source build. We don't need upstream's self-test to produce
    # a linkable library, so patch it out of a copy fetched fresh from the
    # tap (keeping it in sync with version/checksum bumps rather than
    # vendoring a copy that'll drift). This is a real trade-off, not a free
    # win: it also means we skip whatever regression coverage that test
    # suite provided for this exact build.
    PATCHED_DIR="$WORK_DIR/patched-formulas"
    mkdir -p "$PATCHED_DIR"
    PATCHED_PATHS=()

    for FORMULA in "${TO_BUILD[@]}"; do
      PATCHED_FILE="$PATCHED_DIR/$FORMULA.rb"
      
      # Fetch formula source via API instead of `brew cat` (which requires
      # a full local tap clone, unavailable in modern API-based Homebrew)
      # Prefer lowercase default tap name for raw.githubusercontent.com paths.
      FORMULA_TAP=$(echo "$BREW_INFO_JSON" | jq -r --arg name "$FORMULA" '.[] | select(.name == $name) | .tap // "homebrew/homebrew-core"')
      FORMULA_GIT_HEAD=$(echo "$BREW_INFO_JSON" | jq -r --arg name "$FORMULA" '.[] | select(.name == $name) | .tap_git_head')
      FORMULA_SOURCE_PATH=$(echo "$BREW_INFO_JSON" | jq -r --arg name "$FORMULA" '.[] | select(.name == $name) | .ruby_source_path // "Formula/\($name).rb"')
      
      # Fall back to HEAD if tap_git_head is not available
      FORMULA_GIT_HEAD=${FORMULA_GIT_HEAD:-HEAD}
      
      FORMULA_RAW_URL="https://raw.githubusercontent.com/$FORMULA_TAP/$FORMULA_GIT_HEAD/$FORMULA_SOURCE_PATH"
      
      # Try primary URL; if it fails (404), try a lowercase tap path as a fallback.
      if ! curl -fsSL "$FORMULA_RAW_URL" | sed '/system "make", "HARNESS_JOBS=/d' > "$PATCHED_FILE"; then
        FORMULA_TAP_LOWER=$(echo "$FORMULA_TAP" | tr '[:upper:]' '[:lower:]')
        FORMULA_RAW_URL2="https://raw.githubusercontent.com/$FORMULA_TAP_LOWER/$FORMULA_GIT_HEAD/$FORMULA_SOURCE_PATH"
        if curl -fsSL "$FORMULA_RAW_URL2" | sed '/system "make", "HARNESS_JOBS=/d' > "$PATCHED_FILE"; then
          echo "Fetched formula from fallback URL using lowercased tap: $FORMULA_RAW_URL2"
        else
          echo "Failed to fetch formula source from $FORMULA_RAW_URL and $FORMULA_RAW_URL2" >&2
          exit 1
        fi
      fi
      
      PATCHED_PATHS+=("$PATCHED_FILE")
    done

    # Build fresh if not yet installed on the other-arch Homebrew; reinstall
    # (still forcing a source build) if a previous run already bottled it in.
    # Modern Homebrew rejects formula files that are not in a tap, so create a
    # temporary tap in the other-arch Homebrew and copy the patched formulae
    # into it, then install by tap-qualified name.
    if [ ${#PATCHED_PATHS[@]} -gt 0 ]; then
      TAP_USER="local"
      TAP_REPO="patched-$(date +%s)"
      TAP_NAME="$TAP_USER/$TAP_REPO"

      echo "Creating temporary tap $TAP_NAME on $ARCH_OTHER Homebrew"
      arch "-$ARCH_OTHER" "$BREW_OTHER" tap-new "$TAP_NAME"

      # Determine the other-arch Homebrew repository location (run under that arch)
      HOMEBREW_REPO_OTHER=$(arch "-$ARCH_OTHER" "$BREW_OTHER" --repository)
      TAP_DIR="$HOMEBREW_REPO_OTHER/Library/Taps/$TAP_USER/homebrew-$TAP_REPO"
      mkdir -p "$TAP_DIR/Formula"

      # Copy patched formula files into the tap's Formula directory.
      for PF in "${PATCHED_PATHS[@]}"; do
        cp "$PF" "$TAP_DIR/Formula/"
      done

      # Install from the tap by tap-qualified name (forces build-from-source).
      INSTALL_TARGETS=()
      for FORMULA in "${TO_BUILD[@]}"; do
        INSTALL_TARGETS+=("$TAP_NAME/$FORMULA")
      done

      if ! arch "-$ARCH_OTHER" "$BREW_OTHER" install --build-from-source "${INSTALL_TARGETS[@]}"; then
        arch "-$ARCH_OTHER" "$BREW_OTHER" reinstall --build-from-source "${INSTALL_TARGETS[@]}"
      fi

      # Untap to clean up the temporary tap (ignore failures).
      arch "-$ARCH_OTHER" "$BREW_OTHER" untap "$TAP_NAME" || true
    fi
  fi

  for SOURCE_FORMULA in "${SOURCE_FORMULAE[@]}"; do
    SOURCE_VERSION=$(echo "$BREW_INFO_JSON" | jq -r --arg name "$SOURCE_FORMULA" '.[] | select(.name == $name) | .versions.stable')
    SOURCE_CELLAR_DIR="$HOMEBREW_CELLAR_OTHER/$SOURCE_FORMULA/$SOURCE_VERSION"

    if [ ! -d "$SOURCE_CELLAR_DIR" ]; then
      # Revision suffixes (e.g. "_1") aren't part of versions.stable, so fall
      # back to whatever's actually there. `ls -t` (unlike GNU-only
      # `sort -V`) works with both BSD (macOS) and GNU sort/ls, and the
      # formula we just built/reinstalled will be the most recently modified
      # entry.
      SOURCE_CELLAR_DIR=$(ls -t "$HOMEBREW_CELLAR_OTHER/$SOURCE_FORMULA" 2>/dev/null | head -n1)
      [ -n "$SOURCE_CELLAR_DIR" ] && SOURCE_CELLAR_DIR="$HOMEBREW_CELLAR_OTHER/$SOURCE_FORMULA/$SOURCE_CELLAR_DIR"
    fi

    if [ -z "$SOURCE_CELLAR_DIR" ] || [ ! -d "$SOURCE_CELLAR_DIR" ]; then
      echo "Built $SOURCE_FORMULA from source but found nothing under $HOMEBREW_CELLAR_OTHER/$SOURCE_FORMULA" >&2
      exit 1
    fi

    # Stage it the same way a downloaded-and-extracted bottle would land,
    # so the merge loop below doesn't need to know how it got here.
    mkdir -p "$WORK_DIR/$SOURCE_FORMULA"
    cp -R "$SOURCE_CELLAR_DIR" "$WORK_DIR/$SOURCE_FORMULA/"
  done
fi

for MERGING_LIB in $(find $WORK_DIR -iname '*.dylib' -type f); do
  EXISTING_LIB="${MERGING_LIB/$WORK_DIR/$HOMEBREW_PREFIX/Cellar}"
  MERGING_ARCH=$(lipo -archs $MERGING_LIB)

  if [ ! -f $EXISTING_LIB ]; then
    echo "$EXISTING_LIB does not exist to merge $MERGING_LIB [$MERGING_ARCH]"
    continue
  fi

  EXISTING_ARCH=$(lipo -archs $EXISTING_LIB)

  if [ "$EXISTING_ARCH" = "x86_64 arm64" ]; then
    echo "$EXISTING_LIB [$EXISTING_ARCH] -> already universal"
    continue
  fi

  BACKUP_FILENAME=${EXISTING_LIB%.dylib}.$EXISTING_ARCH.dylib

  echo "$EXISTING_LIB [$EXISTING_ARCH] -> $BACKUP_FILENAME and merging $MERGING_LIB [$MERGING_ARCH]"

  if [ ! -f $BACKUP_FILENAME ]; then
    cp $EXISTING_LIB $BACKUP_FILENAME
  fi

  INSTALL_NAME_TOOL_ARGS=""

  for DEP_LIB_FILENAME in $(otool -L -arch $ARCH_OTHER $MERGING_LIB | grep -Eo '@@HOMEBREW_(PREFIX|CELLAR)@@\S+'); do
    NEW_DEP_LIB_FILENAME=${DEP_LIB_FILENAME/@@HOMEBREW_PREFIX@@/$HOMEBREW_PREFIX_OTHER}
    NEW_DEP_LIB_FILENAME=${NEW_DEP_LIB_FILENAME/@@HOMEBREW_CELLAR@@/$HOMEBREW_CELLAR_OTHER}

    if [ "$(basename $NEW_DEP_LIB_FILENAME)" == "$(basename $MERGING_LIB)" ]; then
      INSTALL_NAME_TOOL_ARGS+="-id $NEW_DEP_LIB_FILENAME "
    else
      INSTALL_NAME_TOOL_ARGS+="-change $DEP_LIB_FILENAME $NEW_DEP_LIB_FILENAME "
    fi
  done

  if [ ${#INSTALL_NAME_TOOL_ARGS} -ne 0 ]; then
    install_name_tool $INSTALL_NAME_TOOL_ARGS $MERGING_LIB
  fi

  lipo -create $BACKUP_FILENAME $MERGING_LIB -output $EXISTING_LIB
  codesign -s - $EXISTING_LIB || true
done

rm -rf $WORK_DIR
